{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "GamePulseTracker Companion",
    "author": "NekoSuneProjects",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.241.0",
    "description": "Posts in-game stats to your self-hosted GamePulseTracker server. Works for games where the official APIs are not available (CoD, Warframe, Arc Raiders, Marvel Rivals, etc.)",
    "icon": "icons/icon-256.png",
    "icon_gray": "icons/icon-256-gray.png",
    "launcher_icon": "icons/icon-256.ico"
  },
  "permissions": [
    "GameInfo",
    "Hotkeys",
    "Streaming",
    "FileSystem",
    "Profile",
    "DesktopStreaming"
  ],
  "data": {
    "start_window": "settings",
    "windows": {
      "background": {
        "file": "background.html",
        "is_background_page": true
      },
      "settings": {
        "file": "settings.html",
        "transparent": false,
        "show_in_taskbar": true,
        "resizable": true,
        "size": { "width": 800, "height": 640 },
        "min_size": { "width": 480, "height": 360 }
      },
      "in_game": {
        "file": "in-game.html",
        "transparent": true,
        "in_game_only": true,
        "clickthrough": true,
        "size": { "width": 360, "height": 220 },
        "show_in_taskbar": false
      }
    },
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [
        21216, 21566, 21640, 5426, 10826, 10906, 10798, 10844,
        9898, 21570, 21509, 8032, 10844, 21277, 21626
      ]
    },
    "game_events": [
      21216, 21566, 21640, 5426, 10826, 10906, 10798, 10844
    ],
    "launch_events": [
      {
        "event": "GameLaunch",
        "tracked": false,
        "event_data": { "game_ids": [21216, 21566, 21640, 5426, 10826, 10906, 10798, 10844] },
        "start_minimized": false
      }
    ]
  }
}
