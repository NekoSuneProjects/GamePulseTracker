// GamePulseTracker — Prisma schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Users + auth
// ----------------------------------------------------------------------------
enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  role          Role     @default(USER)
  emailVerified Boolean  @default(false)
  avatarUrl     String?
  publicProfile Boolean  @default(true)
  bio           String?
  /// SocialLink[] from @gpt/shared (twitter/twitch/youtube/...).
  socials       Json     @default("[]")

  /// Set when the user requests account deletion. Login is blocked, account
  /// is invisible to others, and a scheduled job hard-deletes once the grace
  /// window passes. Users can cancel by signing in again before that.
  deletionRequestedAt DateTime?
  /// Scheduled hard-delete timestamp (deletionRequestedAt + 30d, by default).
  deletionAt          DateTime?

  /// TOTP secret (base32) once the user enrols. Null when 2FA is off.
  totpSecret    String?
  /// Set when the user has successfully verified one TOTP code after enrol.
  totpEnabled   Boolean   @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions             Session[]
  linkedAccounts       LinkedAccount[]
  trackedProfiles      TrackedProfile[]
  notifications        Notification[]
  passwordResets       PasswordReset[]
  apiKeys              ApiKey[]
  devices              Device[]
  deletionRequests     StatsDeletionRequest[] @relation("DeletionRequester")
  deletionsResolved    StatsDeletionRequest[] @relation("DeletionResolver")
  favorites            Favorite[]
  follows              Follow[] @relation("Follower")
  followers            Follow[] @relation("Followed")
  activityEvents       ActivityEvent[]
  achievements         UserAchievement[]

  @@index([role])
  @@index([deletionAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshHash  String
  userAgent    String?
  ip           String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  label     String
  keyHash   String   @unique
  prefix    String   // first 8 chars for display
  rateLimit Int      @default(60) // requests per minute
  lastUsed  DateTime?
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ----------------------------------------------------------------------------
// External platform linking (EA, Steam, Bungie, Epic, ...)
// ----------------------------------------------------------------------------
model LinkedAccount {
  id            String   @id @default(cuid())
  userId        String
  platform      String   // 'epic', 'ea', 'steam', 'bungie', 'riot', 'xbl', 'psn', 'discord', 'minecraft', 'activision'
  providerId    String   // platform's CURRENT stable id (uuid, steamid64, bungie membership id, ...)
  displayName   String

  /// JSON blob with provider-specific fields (oauth tokens, refresh tokens, etc.)
  /// Tokens should be encrypted at rest in production.
  meta          Json     @default("{}")
  verified      Boolean  @default(false)

  /// IdentityHistoryEntry[] — captures previous providerIds the same linked
  /// account used to resolve to. Updated by the IdentityResolveScheduler
  /// whenever the platform's username→stable-id mapping changes.
  identityHistory Json   @default("[]")
  /// When we last verified providerId still matches what the platform reports.
  lastResolvedAt DateTime?
  /// Optional autoResolve flag — defaults true, can be turned off per-account.
  autoResolve    Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, providerId])
  @@index([userId])
  @@index([platform])
  @@index([lastResolvedAt])
}

// ----------------------------------------------------------------------------
// Per-game player profiles tracked by the platform
// (Composite key includes platform so e.g. PSN Apex and Origin Apex are distinct.)
// ----------------------------------------------------------------------------
model TrackedProfile {
  id            String   @id @default(cuid())
  /// Null if this profile is unclaimed.
  userId        String?
  game          String   // GameSlug from shared catalog
  /// '_' for platform-agnostic games (Hypixel, Wynncraft, OSRS, RS3, ...).
  platform      String   @default("_")
  providerId    String   // stable id within the game's own provider
  displayName   String
  avatarUrl     String?

  /// Latest normalized snapshot from integration (NormalizedProfile JSON).
  latestSnapshot Json?
  providerUpdatedAt DateTime?
  lastFetchedAt    DateTime?
  lastAttemptedAt  DateTime?
  /// Per-profile refresh interval override (ms).
  refreshIntervalMs Int?
  active        Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  matches   MatchRecord[]
  seasons   SeasonRecord[]
  snapshots StatSnapshot[]
  deletionRequests StatsDeletionRequest[]
  favorites Favorite[]

  @@unique([game, platform, providerId])
  @@index([userId])
  @@index([game, platform])
  @@index([lastFetchedAt])
}

model StatSnapshot {
  id          String   @id @default(cuid())
  profileId   String
  payload     Json
  level       Int?
  xp          BigInt?
  rank        String?
  rankTier    Int?
  kd          Float?
  wins        Int?
  losses      Int?
  matches     Int?
  createdAt   DateTime @default(now())

  profile TrackedProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
}

model MatchRecord {
  id           String   @id @default(cuid())
  profileId    String
  matchId      String
  playedAt     DateTime
  mode         String?
  map          String?
  result       String?
  kills        Int?
  deaths       Int?
  assists      Int?
  score        Int?
  durationSec  Int?
  details      Json?

  profile TrackedProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, matchId])
  @@index([profileId, playedAt])
}

model SeasonRecord {
  id          String   @id @default(cuid())
  profileId   String
  seasonId    String
  label       String
  startedAt   DateTime?
  endedAt     DateTime?
  rank        String?
  rankTier    Int?
  stats       Json     @default("{}")

  profile TrackedProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, seasonId])
  @@index([profileId])
}

// ----------------------------------------------------------------------------
// Leaderboards (cached)
// ----------------------------------------------------------------------------
model LeaderboardSnapshot {
  id        String   @id @default(cuid())
  game      String
  platform  String   @default("_")
  metric    String
  payload   Json
  createdAt DateTime @default(now())

  @@unique([game, platform, metric, createdAt])
  @@index([game, platform, metric])
}

// ----------------------------------------------------------------------------
// Cached raw integration responses
// ----------------------------------------------------------------------------
model IntegrationCache {
  id        String   @id @default(cuid())
  game      String
  endpoint  String
  key       String
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([game, endpoint, key])
  @@index([expiresAt])
}

// ----------------------------------------------------------------------------
// News (per game, aggregated from RSS / integration getNews)
// ----------------------------------------------------------------------------
model NewsItem {
  id          String   @id            // stable id from source (URL hash or guid)
  game        String
  title       String
  url         String
  source      String
  summary     String?  @db.Text
  imageUrl    String?
  tags        Json     @default("[]")
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  @@index([game, publishedAt])
  @@unique([game, url])
}

// ----------------------------------------------------------------------------
// Notifications
// ----------------------------------------------------------------------------
model Notification {
  id        String   @id @default(cuid())
  userId    String
  level     String   @default("info")
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ----------------------------------------------------------------------------
// Favorites — user-bookmarked TrackedProfiles. Show alongside Recent Players.
// ----------------------------------------------------------------------------
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  profileId String
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile TrackedProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([userId, createdAt])
}

// ----------------------------------------------------------------------------
// Stats deletion requests (user → admin approval queue)
//
// A user with verified ownership of a TrackedProfile (either it's userId
// matches them, or they hold a LinkedAccount that resolves to the same
// (platform, providerId)) can request the full erasure of that profile's
// stats. An admin approves, which cascade-deletes the TrackedProfile and
// every StatSnapshot/MatchRecord/SeasonRecord descended from it.
// ----------------------------------------------------------------------------
enum DeletionStatus {
  PENDING
  APPROVED
  REJECTED
}

model StatsDeletionRequest {
  id          String         @id @default(cuid())
  userId      String
  profileId   String
  reason      String?
  status      DeletionStatus @default(PENDING)
  adminId     String?
  adminNote   String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())

  user    User           @relation("DeletionRequester", fields: [userId], references: [id], onDelete: Cascade)
  admin   User?          @relation("DeletionResolver",  fields: [adminId], references: [id], onDelete: SetNull)
  profile TrackedProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
  @@index([profileId])
}

// ----------------------------------------------------------------------------
// Social — follow + activity feed + achievements
// ----------------------------------------------------------------------------
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followedId  String
  createdAt   DateTime @default(now())

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("Followed", fields: [followedId], references: [id], onDelete: Cascade)

  @@unique([followerId, followedId])
  @@index([followerId])
  @@index([followedId])
}

/// Public activity feed entries — emitted by the stats refresh processor
/// when a tracked profile owned by a user crosses a threshold (level-up,
/// rank change). The feed page reads these as a chronological list per user.
/// `payload` is a JSON object specific to the `kind` (e.g.
/// `{ from: 'Gold', to: 'Platinum' }` for rank-change).
model ActivityEvent {
  id          String   @id @default(cuid())
  userId      String
  /// Optional — which TrackedProfile triggered the event.
  profileId   String?
  /// One of: level-up | rank-change | follow | achievement
  kind        String
  payload     Json     @default("{}")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

/// Per-user-achievement unlock log. The set of achievements is hardcoded in
/// the backend (see achievements/criteria.ts) so we don't need to model the
/// catalog in Prisma. `slug` is the canonical id; one row per (user, slug).
model UserAchievement {
  id        String   @id @default(cuid())
  userId    String
  slug      String
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
}

// ----------------------------------------------------------------------------
// Audit log
// ----------------------------------------------------------------------------
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId])
}

// ----------------------------------------------------------------------------
// Companion devices (Overwolf overlay, desktop ingest clients)
// ----------------------------------------------------------------------------
model Device {
  id        String   @id @default(cuid())
  userId    String
  label     String                          // user-chosen, e.g. "Gaming PC Overwolf"
  /// SHA-256 of the device key. The plaintext key is shown ONCE on pairing.
  keyHash   String   @unique
  prefix    String                           // first 8 chars for display
  /// Which game slugs this device is allowed to ingest for. Empty = all.
  scopes    Json     @default("[]")
  /// Pairing code (short, user-readable) and its expiry, only set during pairing.
  pairingCode      String?
  pairingExpiresAt DateTime?
  rateLimit Int      @default(120)           // ingest events per minute
  lastSeen  DateTime?
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pairingCode])
}

// ----------------------------------------------------------------------------
// Ingest events (every payload posted by a Device, retained for audit/replay).
// ----------------------------------------------------------------------------
model IngestEvent {
  id        String   @id @default(cuid())
  deviceId  String
  game      String
  platform  String   @default("_")
  providerId String
  /// Full IngestPayload from @gpt/shared.
  payload   Json
  createdAt DateTime @default(now())

  @@index([deviceId, createdAt])
  @@index([game, providerId, createdAt])
}
