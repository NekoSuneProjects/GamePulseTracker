# ============================================================
# GamePulseTracker — environment variables
# Copy to .env and fill in. Never commit the real .env.
# ============================================================

# ---- Core ----
NODE_ENV=development
TZ=UTC

# ---- Backend ----
BACKEND_PORT=4000

# Browsers enforce CORS on credentialed/POST requests. Set this to the SAME
# origin(s) your users will see in their address bar — i.e. the public URL of
# the whole site, NOT the backend host.
#
#  - Local dev (frontend on :3000, backend on :4000 — different origins):
#      CORS_ORIGINS=http://localhost:3000
#
#  - Production behind nginx (frontend + backend share one domain):
#      CORS_ORIGINS=https://yourgametracker.com
#
#  - Multiple frontends (comma-separated):
#      CORS_ORIGINS=https://yourgametracker.com,https://admin.yourgametracker.com
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
FRONTEND_PORT=3000

# NEXT_PUBLIC_API_URL is BAKED INTO THE FRONTEND BUILD. Pick the right one:
#
#  - Local development (no nginx, backend exposed on host 4000):
#      NEXT_PUBLIC_API_URL=http://localhost:4000
#
#  - Production behind nginx (this is the default deployment shape):
#      NEXT_PUBLIC_API_URL=/api
#    OR leave blank — the frontend falls back to `${origin}/api` automatically.
#
#  - Frontend on one host, backend on another (split deployment):
#      NEXT_PUBLIC_API_URL=https://api.yourgametracker.com
#
# If you set it to a same-origin URL (e.g. http://your.host:port) WITHOUT /api,
# the frontend auto-appends /api so it doesn't 404 against itself.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WS_URL=

# ---- PostgreSQL ----
POSTGRES_USER=gamepulse
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=gamepulse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://gamepulse:change_me_in_prod@postgres:5432/gamepulse?schema=public

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Auth ----
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ---- Public API ----
PUBLIC_API_RATE_LIMIT_PER_MIN=60
PUBLIC_API_ENABLED=true

# ---- Worker tuning ----
STATS_REFRESH_INTERVAL_MS=300000   # 5 min per-profile refresh
QUEUE_CONCURRENCY=8

# ============================================================
# Google AdSense (optional, frontend-only)
# Leave blank to disable ads. When NEXT_PUBLIC_ADSENSE_CLIENT is
# set, the frontend loads adsbygoogle.js, renders <AdSlot/>
# components, and shows a polite notice to ad-blocker users.
# ============================================================
NEXT_PUBLIC_ADSENSE_CLIENT=          # ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
NEXT_PUBLIC_ADBLOCK_NOTICE=true

# ============================================================
# Game integration credentials — grouped by status (2026).
# Endpoints listed are what we actually hit. Fill only the env
# vars for games you want to enable.
# ============================================================

# ---- LIVE, no key needed ----------------------------------
#  OSRS          : https://secure.runescape.com/m=hiscore_oldschool/index_lite.ws?player=NAME
#  RuneScape 3   : https://secure.runescape.com/m=hiscore/index_lite.ws?player=NAME
#  Wynncraft     : https://api.wynncraft.com/v3/player/<name>
#  Warframe WS   : https://api.warframestat.us/<pc|ps4|xb1|swi>
#  Warframe Mkt  : https://api.warframe.market/v1/profile/<name>/statistics
#  Roblox        : https://users.roblox.com/v1/usernames/users   (POST)
#  Beat Saber    : https://scoresaber.com/api/player/<id>/full   (ScoreSaber)

# ---- LIVE, free key required ------------------------------
# Hypixel  -> https://developer.hypixel.net
HYPIXEL_API_KEY=

# Wargaming (WoT / WoWS / WoWp)  -> https://developers.wargaming.net/applications/
WARGAMING_APPLICATION_ID=

# ---- Stubs ready for credentials -------------------------
# Each file under backend/src/games/integrations/<slug>/ has the exact
# endpoint to wire in its header comment.

# Fortnite       -> https://dash.fortnite-api.com/
FORTNITE_API_KEY=
# Apex Legends   -> https://apexlegendsapi.com/  (Mozambique Here)
APEX_API_KEY=
# Steam (CS2)    -> https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Rocket League  -> https://ballchasing.com/upload  (BallChasing.com, free)
ROCKET_LEAGUE_API_KEY=
# Battlefield    -> https://api.gametools.network/  (community gametools)
BATTLEFIELD_API_KEY=
# Overwatch 2    -> https://overfast-api.tekrop.fr/  (community proxy, no key)
OVERWATCH_API_KEY=
# Halo Infinite  -> https://api.haloapi.com (Microsoft official, partner-only)
#                   OR a community HaloDotAPI mirror. autocode.com is dead.
HALO_API_KEY=

# ---- Restricted keys (review/approval required) ----------
# Bungie (D1 + D2)  -> https://www.bungie.net/en/Application
BUNGIE_API_KEY=
BUNGIE_OAUTH_CLIENT_ID=
BUNGIE_OAUTH_CLIENT_SECRET=

# Riot (Valorant + LoL + TFT)  -> https://developer.riotgames.com
# Production keys require a published-app review by Riot. Community
# fallback for Valorant: https://github.com/Henrik-3/unofficial-valorant-api
RIOT_API_KEY=

# Rainbow Six Siege  -> https://r6stats.com/  (community, sign-up required)
R6_API_KEY=

# ---- No public API / companion-ingest only ---------------
# Until a community provider exists, pair the Overwolf companion
# from /devices and POST stats to /ingest/<slug>.
SPLITGATE_API_KEY=
MARVEL_RIVALS_API_KEY=
DIVISION_API_KEY=
DIVISION2_API_KEY=
FOR_HONOR_API_KEY=
BLOODHUNT_API_KEY=
# CoD (Warzone 2.0, Cold War, MWII, MWIII, BO6) — Activision shut down the
# public stats API in 2022 and hasn't replaced it. Companion ingest only.
COD_API_KEY=

# ---- VRChat (worlds-only, no PII) ------------------------
# The backend logs into VRChat with these credentials and caches the session
# cookie in Redis, auto-refreshing on 401. Recommended: create a dedicated
# VRChat account for the server and turn on TOTP 2FA on it.
#
#   VRCHAT_USER_AGENT    Per VRChat ToS — identify the operator + contact.
#   VRCHAT_USERNAME      VRChat login (email or username).
#   VRCHAT_PASSWORD      VRChat password.
#   VRCHAT_TOTP_SECRET   ONLY if 2FA is enabled on the account. It's the
#                        base32 secret shown when you set up an authenticator
#                        app (the long string under the QR code). Leave
#                        blank when 2FA is off. Email OTP cannot be
#                        automated — switch the account to TOTP if needed.
#
# The integration ONLY queries worlds endpoints — no user/friends/messages.
VRCHAT_USER_AGENT=GamePulseTracker/0.1 (self-hosted; contact: ops@yourdomain)
VRCHAT_USERNAME=
VRCHAT_PASSWORD=
VRCHAT_TOTP_SECRET=

# ============================================================
# OAuth providers (account linking)
# ============================================================
EPIC_OAUTH_CLIENT_ID=
EPIC_OAUTH_CLIENT_SECRET=

DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=

STEAM_OPENID_REALM=http://localhost:4000
STEAM_OPENID_RETURN=http://localhost:4000/auth/steam/callback

# ============================================================
# Mail (optional, for verification + password reset)
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GamePulseTracker <noreply@example.com>

# ============================================================
# Overwolf companion download link (frontend-only)
# When set, the /devices page shows a "Download Overwolf app" button
# pointing at this URL. Build overwolf-app/ → .opk and publish on
# your CDN / GitHub Release.
# ============================================================
NEXT_PUBLIC_OVERWOLF_DOWNLOAD_URL=
